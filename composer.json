{
  "name": "skylence/atomic-lock",
  "description": "A Laravel package for atomic locking to prevent race conditions across processes and servers",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "laravel",
    "atomic",
    "lock",
    "mutex",
    "race-condition"
  ],
  "autoload": {
    "psr-4": {
      "Skylence\\AtomicLock\\": "src/"
    }
  },
  "require": {
    "php": "^8.2",
    "illuminate/support": "^11.0|^12.0",
    "illuminate/cache": "^11.0|^12.0"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Skylence\\AtomicLock\\AtomicLockServiceProvider"
      ],
      "aliases": {
        "AtomicLock": "Skylence\\AtomicLock\\Facades\\AtomicLock"
      }
    }
  },
  "require-dev": {
    "captainhookphp/captainhook": "^5.23",
    "larastan/larastan": "^3.0",
    "laravel/pint": "^1.0",
    "orchestra/testbench": "^9.0|^10.0",
    "phpunit/phpunit": "^11.0",
    "rector/rector": "^2.0"
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "test:types": "vendor/bin/phpstan --error-format=table",
    "lint": "vendor/bin/pint",
    "lint:check": "vendor/bin/pint --test",
    "refactor": "vendor/bin/rector",
    "refactor:check": "vendor/bin/rector --dry-run",
    "hooks:install": "vendor/bin/captainhook install"
  },
  "minimum-stability": "stable"
}
